# Core Database Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI / LLM Configuration (Using Gemini via OpenAI SDK)
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-1.5-flash  # (Optional, defaults to gemini-1.5-flash)
# GEMINI_EMBED_MODEL=text-embedding-004  # (Optional, for embeddings)

# Vector Database Configuration
# Local Qdrant (for development)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=  # Leave empty for local

# Qdrant Cloud (recommended for production)
# QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key
# QDRANT_COLLECTION_NAME=college_career_knowledge_gemini

# Vector dimensions (must match your embedding model)
# VECTOR_SIZE=768  # For Gemini text-embedding-004
# VECTOR_SIZE=1536  # For OpenAI text-embedding-3-small

# Deployment Configuration
# ALLOWED_ORIGINS=http://localhost:3000,https://margadarshaka.jk.gov.in
